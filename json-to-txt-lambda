import json
import boto3
import os

# Initialize the S3 client
s3 = boto3.client('s3')

def lambda_handler(event, context):
    # Retrieve the destination bucket from environment variables
    # This keeps your code clean and secure
    DESTINATION_BUCKET = os.environ.get('DESTINATION_BUCKET')
    
    try:
        # 1. Get bucket and key from the S3 trigger event
        source_bucket = event['Records'][0]['s3']['bucket']['name']
        json_key = event['Records'][0]['s3']['object']['key']
        
        # 2. Read the JSON file from the source bucket
        response = s3.get_object(Bucket=source_bucket, Key=json_key)
        json_content = json.loads(response['Body'].read().decode('utf-8'))
        
        # 3. Extract the transcript text
        # Path: results -> transcripts -> first entry -> transcript string
        transcript_text = json_content['results']['transcripts'][0]['transcript']
        
        # 4. Define the output key (changing .json extension to .txt)
        txt_key = json_key.replace('.json', '.txt')
        
        # 5. Save the text file to the destination bucket
        s3.put_object(
            Bucket=DESTINATION_BUCKET,
            Key=txt_key,
            Body=transcript_text
        )
        
        return {
            'statusCode': 200,
            'body': json.dumps(f"Successfully converted {json_key} to {txt_key} in {DESTINATION_BUCKET}")
        }
        
    except Exception as e:
        print(f"Error: {str(e)}")
        return {
            'statusCode': 500,
            'body': json.dumps(f"Error processing file: {str(e)}")
        }
